datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  isAdmin       Boolean        @default(false)
  orders        Order[]
  eventBookings EventBooking[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  category    String
  price       String
  priceNumber Float
  description String
  image       String
  flavors     String
  badge       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id               String            @id @default(uuid())
  user             User              @relation(fields: [userId], references: [id])
  userId           String
  total            Float
  items            OrderItem[]
  paymentStatus    PaymentStatus?
  deliveryTracking DeliveryTracking?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
  flavor    String?
}

model PaymentStatus {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  status    String   // PENDING, PAID, FAILED
  method    String   // COD, CARD, KOKO
  amount    Float
  updatedAt DateTime @updatedAt
}

model DeliveryTracking {
  id          String   @id @default(uuid())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String   @unique
  status      String   // PENDING, PREPARING, SHIPPED, DELIVERED
  updatedAt   DateTime @updatedAt
  description String?
}

model EventBooking {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  eventTitle  String
  eventType   String   // WORKSHOP, INVITATION, TICKET
  eventDate   String
  name        String
  email       String
  phone       String?
  seats       Int      @default(1)
  intakeNotes String?
  ticketCode  String?
  createdAt   DateTime @default(now())
}
